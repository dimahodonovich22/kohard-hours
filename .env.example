# Конфиг Firebase-проекта (Project settings → General → Your apps → Web app)
# Скопируйте этот файл в .env и подставьте реальные значения.
# Без .env приложение подключается к локальным эмуляторам (npm run emulators).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# true = принудительно использовать эмуляторы даже с заполненным конфигом
VITE_USE_EMULATORS=false
